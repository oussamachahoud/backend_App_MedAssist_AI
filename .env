# ── Application ───────────────────────────────────────────
APP_NAME="Skin Lesion AI API"
API_VERSION="1.0.0"
DEBUG=False

# ── Model Paths ───────────────────────────────────────────
MODEL_PATH=app/ml_models/multimodal_model.pth
LE_DIAGNOSTIC_PATH=app/ml_models/le_diagnostic.pkl
LE_REGION_PATH=app/ml_models/le_region.pkl

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Upload Limits ─────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
