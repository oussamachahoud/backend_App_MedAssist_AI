# ── Application ───────────────────────────────────────────
APP_NAME="MedAssist AI API"
API_VERSION="2.0.0"
DEBUG=False

# ── Model Paths (V6.0 artifacts) ──────────────────────────
# Place these files in app/ml_models/ after downloading from training run:
#   swa_model_V6.0.pth     → rename to multimodal_model.pth
#   diagnostic_encoder.pkl
#   imputer.pkl
#   scaler.pkl
#   thresholds_V6.0.json
MODEL_PATH=app/ml_models/multimodal_model.pth
LE_DIAGNOSTIC_PATH=app/ml_models/diagnostic_encoder.pkl
IMPUTER_PATH=app/ml_models/imputer.pkl
SCALER_PATH=app/ml_models/scaler.pkl
THRESHOLDS_PATH=app/ml_models/thresholds_V6.0.json

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Upload Limits ─────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
